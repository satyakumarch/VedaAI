NODE_ENV=development
PORT=5000

# MongoDB Atlas — get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vedaai?retryWrites=true&w=majority

# Redis Cloud — get from: https://app.redislabs.com → Database → Connect
REDIS_URL=redis://default:<password>@redis-xxxxx.db.redis.io:PORT

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# AI Providers — set at least one
# Groq (FREE): https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# OpenAI (Paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (Free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_gemini_key_here

# CORS
CORS_ORIGIN=http://localhost:3000

# File upload
MAX_FILE_SIZE_MB=10

# BullMQ queue
QUEUE_CONCURRENCY=3
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000
